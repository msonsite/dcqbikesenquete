# Supabase (verplicht)
# Maak een project op https://supabase.com en vul de waarden in via Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optionele vraag 3 in-/uitschakelen (true = tonen, false/ontbrekend = verbergen)
NEXT_PUBLIC_SHOW_PURCHASE_REASON=false
